# =========================================================================
# Telegram Business Bot — environment configuration
# Copy this file to `.env` for local development. In production (Railway,
# Koyeb, etc.) set these as platform environment variables/secrets instead.
# =========================================================================

# --- Telegram -------------------------------------------------------------
# Bot token from @BotFather. Required.
TELEGRAM_BOT_TOKEN=

# Public HTTPS base URL of this deployment (no trailing slash), used to
# automatically register the Telegram webhook on startup.
# Example: https://your-app.up.railway.app
WEBHOOK_BASE_URL=

# Path the webhook is served on. Defaults to /webhook.
WEBHOOK_PATH=/webhook

# Optional secret token Telegram will echo back in the
# X-Telegram-Bot-Api-Secret-Token header on every webhook call. Strongly
# recommended in production. Generate any random string.
TELEGRAM_WEBHOOK_SECRET=

# --- Server -----------------------------------------------------------
# Port the app listens on. Railway/Koyeb inject this automatically.
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=production
LOG_LEVEL=INFO

# --- Database -----------------------------------------------------------
# Defaults to a local SQLite file if unset. To use PostgreSQL, set this to
# a postgres:// or postgresql:// URL (the app rewrites it to use asyncpg
# automatically).
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# --- Dashboard --------------------------------------------------------
DASHBOARD_ADMIN_USERNAME=
DASHBOARD_ADMIN_PASSWORD=

# Secret key used to sign dashboard session cookies. Generate a long random
# string (e.g. `python -c "import secrets; print(secrets.token_hex(32))"`).
SESSION_SECRET=
SESSION_MAX_AGE_SECONDS=43200
